        "salesforce-1": {
          "title": "Query Draft Items on Non-Draft Orders",
          "connector": {
            "name": "salesforce",
            "version": "8.7"
          },
          "operation": "raw_http_request",
          "output_schema": {},
          "error_handling": {},
          "authentication": {
