        "script-1": {
          "title": "Build Batch Update Payloads",
          "connector": {
            "name": "script",
            "version": "3.4"
          },
          "operation": "execute",
          "output_schema": {},
          "error_handling": {},
          "properties": {
            "variables": {
              "type": "array",
              "value": [
                {
                  "type": "object",
                  "value": {
                    "name": {
                      "type": "string",
                      "value": "data"
                    },
                    "value": {
                      "type": "jsonpath",
                      "value": "$.steps.salesforce-1.response.body.records"
                    }
                  }
                }
              ]
            },
            "script": {
              "type": "string",
              "value": "exports.step = function(input, fileInput) {\n  var records = input.data;\n\n  var batchUpdateList = records.map(function(record) {\n    return {\n      object_id: record.Id,\n      fields: [\n        {\n          key: \"ohfy__Is_Draft__c\",\n          value: false\n        }\n      ]\n    };\n  });\n\n  return [\n    {\n      object: \"ohfy__Order_Item__c\",\n      error_handling: \"rollback_fail\",\n      batch_update_list: batchUpdateList,\n      totalRecords: records.length\n    }\n  ];\n};"
            },
            "file_output": {
              "type": "boolean",
              "value": false
            }
          }
        },
