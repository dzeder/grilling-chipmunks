            "title": "TBM PRODUCTION OHANAFY 2025-12-15",
            "service_icon": {
              "icon_type": "url",
              "value": "https://s3.amazonaws.com/images.tray.io/artisan/icons/dd966f42-81e8-4770-a3d8-d095ca41ab45.png"
            },
            "scopes": [
              "full",
              "refresh_token"
            ],
            "service_name": "salesforce",
            "service_version": 1
          },
          "properties": {
            "method": {
              "type": "string",
              "value": "GET"
            },
            "include_raw_body": {
              "type": "boolean",
              "value": false
            },
            "parse_response": {
              "type": "string",
              "value": "true"
            },
            "url": {
              "type": "object",
              "value": {
                "endpoint": {
                  "type": "string",
                  "value": "services/data/v62.0/query"
                }
              }
            },
            "query_parameters": {
              "type": "array",
              "value": [
                {
                  "type": "object",
                  "value": {
                    "key": {
                      "type": "string",
                      "value": "q"
                    },
                    "value": {
                      "type": "string",
                      "value": "SELECT Id, ohfy__Is_Draft__c, ohfy__Order__r.ohfy__Status__c, ohfy__Order__r.ohfy__Delivery_Pickup_Date__c FROM ohfy__Order_Item__c WHERE ohfy__Is_Draft__c = true AND ohfy__Order__r.ohfy__Status__c != 'Draft' AND ohfy__Order__r.ohfy__Delivery_Pickup_Date__c > TODAY"
                    }
                  }
                }
              ]
            },
            "body": {
              "type": "object",
              "value": {
                "none": {
                  "type": "null",
                  "value": null
                }
              }
            }
          }
        },
