    "salesforce_composite_response_processing": {
      "name": "Salesforce Composite Response Processing",
      "description": "Process Salesforce composite API responses with comprehensive error handling",
      "source": "Shopify_2GP/versions/current/scripts/scripts/Shopify_02_Products/2-execute_script/script.js",
      "complexity": "advanced",
      "patterns_used": [
        "salesforce_composite_response_handler",
        "error_types_enumeration",
        "http_status_to_error_type_mapping",
        "retry_strategy_pattern"
      ],
      "input_example": {
        "compositeResponse": [
          {
            "body": {
              "id": "a0X5e000001234ABC",
              "success": true,
              "created": true
            },
            "httpHeaders": {
              "Location": "/services/data/v61.0/sobjects/Item__c/a0X5e000001234ABC"
            },
            "httpStatusCode": 201,
            "referenceId": "Item1"
          },
          {
            "body": [
              {
                "errorCode": "REQUIRED_FIELD_MISSING",
                "message": "Required fields are missing: [Name]",
                "fields": ["Name"]
              }
            ],
            "httpStatusCode": 400,
            "referenceId": "Item2"
          }
        ]
      },
      "output_example": {
        "successful_operations": [
          {
            "salesforce_id": "a0X5e000001234ABC",
            "reference_id": "Item1",
            "operation_type": "created",
            "http_status": 201,
            "location": "/services/data/v61.0/sobjects/Item__c/a0X5e000001234ABC",
            "success": true
          }
        ],
        "errors": [
          {
            "error": {
              "response": {
                "body": {
                  "Type": "ValidationFailed",
                  "Message": "Required fields are missing: [Name]",
                  "ErrorCode": "REQUIRED_FIELD_MISSING"
                }
              },
              "message": "Required fields are missing: [Name]",
              "statusCode": 400,
              "retryable": false,
              "retryStrategy": {
                "maxRetries": 0,
                "delayMs": null,
                "backoffMultiplier": 1,
                "recommendation": "Not retryable, fix error and resubmit"
              }
            },
            "id": "Salesforce Operation Reference # Item2",
            "service": "Salesforce Composite API Processing",
            "fields": ["Name"]
          }
        ],
        "summary": {
          "total_operations": 2,
          "successful_operations": 1,
          "failed_operations": 1,
          "records_created": 1,
          "records_updated": 0,
          "success_rate": 50
        },
        "total_responses": 2,
        "processed_at": "2025-01-25T10:30:00.000Z"
      }
    },
